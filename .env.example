# GCP Project Configuration
PROJECT_ID=your-gcp-project-id
REGION=us-central1
CLUSTER_NAME=ladybugdb-cluster

# GCS Bucket for database storage
BUCKET_NAME=ladybugdb-database-your-project

# Namespace
NAMESPACE=ladybugdb

# GCP Service Account for Workload Identity
GSA_NAME=ladybugdb-gsa
KSA_NAME=ladybugdb-sa

# LadybugDB configuration
LBUG_FILE=database.lbdb
# Buffer pool size in bytes (default: 1GB)
LBUG_BUFFER_POOL_SIZE=1073741824
# Access mode: READ_WRITE or READ_ONLY
LBUG_MODE=READ_WRITE
